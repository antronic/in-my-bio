---
import Layout from '../layouts/Layout.astro';
import { Card, CardDescription, CardHeader, CardTitle } from '../components/ui/card';
import postsData from '../data/posts.json';

// Posts from JSON
const { posts } = postsData;
---

<Layout title="@job.jirachai | Links">
  <div class="container mx-auto px-4 py-12 max-w-2xl">
    <!-- Profile Section -->
    <div class="text-center mb-12">
      <div class="mx-auto w-24 h-24 mb-4">
        <img 
          src="/profile.jpg"
          alt="@job.jirachai" 
          class="w-full h-full rounded-full object-cover ring-4 ring-primary/10"
        />
      </div>
      <a 
        href="https://www.instagram.com/job.jirachai/" 
        class="text-xl font-semibold hover:text-primary/80 transition-colors"
      >
        @job.jirachai
      </a>
    </div>

    <!-- Links Section -->
    <div class="space-y-4">
      <h2 class="text-lg font-medium text-muted-foreground mb-6 text-center">Links</h2>
      
      {posts.map((post) => (
        <a href={post.url} target="_blank" rel="noopener noreferrer" class="block">
          <Card className="overflow-hidden hover:shadow-lg transition-all duration-200 hover:scale-[1.02] cursor-pointer group">
            <div class="flex">
              <div class="w-24 h-24 flex-shrink-0">
                <img 
                  src={post.image} 
                  alt={post.title}
                  class="w-full h-full object-cover"
                />
              </div>
              <CardHeader className="flex-1 py-4 px-4">
                <CardTitle className="text-base group-hover:text-primary transition-colors">
                  {post.title}
                </CardTitle>
                <CardDescription className="line-clamp-2">
                  {post.description}
                </CardDescription>
              </CardHeader>
            </div>
          </Card>
        </a>
      ))}
    </div>

    <!-- Footer -->
    <footer class="mt-12 text-center text-sm text-muted-foreground">
      <p>© {new Date().getFullYear()} @job.jirachai</p>
    </footer>
  </div>
</Layout>
